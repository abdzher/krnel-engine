---
apiVersion: traefik.io/v1alpha1
kind: Middleware
metadata:
  name: longhorn-ui-ipallowlist
  namespace: {{ longhorn_namespace }}
spec:
  ipAllowList:
    sourceRange:
{% for cidr in longhorn_ui_allowed_cidrs %}
      - {{ cidr }}
{% endfor %}
---
apiVersion: networking.k8s.io/v1
kind: Ingress
metadata:
  name: longhorn-ui
  namespace: {{ longhorn_namespace }}
  annotations:
    kubernetes.io/ingress.class: traefik
    traefik.ingress.kubernetes.io/router.middlewares: {{ longhorn_namespace }}-longhorn-ui-ipallowlist@kubernetescrd
spec:
  ingressClassName: traefik
  rules:
    - host: {{ longhorn_domain }}
      http:
        paths:
          - path: /
            pathType: Prefix
            backend:
              service:
                name: longhorn-frontend
                port:
                  number: 80
