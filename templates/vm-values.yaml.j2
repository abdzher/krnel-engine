# ==============================================================================
# KRNEL — templates/vm-values.yaml.j2
# Valores para el chart vm/victoria-metrics-k8s-stack
# Renderizado por Ansible — NO editar directamente en el servidor
# ==============================================================================

# VictoriaMetrics Single — motor de base de datos de series temporales
vmsingle:
  enabled: true
  spec:
    retentionPeriod: "{{ victoria_metrics_retention }}"  # meses de retención
    storage:
      storageClassName: {{ storage_class_name }}
      accessModes: ["ReadWriteOnce"]
      resources:
        requests:
          storage: {{ victoria_metrics_storage }}

# Grafana — visualización de métricas
grafana:
  enabled: true
  persistence:
    enabled: true
    storageClassName: {{ storage_class_name }}
  service:
    type: NodePort
    nodePort: {{ victoria_metrics_port }}
  ingress:
    enabled: true
    annotations:
      kubernetes.io/ingress.class: traefik
    hosts:
      - "{{ mrkov_domain }}"
    path: /grafana
  grafana.ini:
    server:
      domain: "{{ mrkov_domain }}"
      root_url: "%(protocol)s://%(domain)s/grafana"
      serve_from_sub_path: true

# VMAgent — recolector de métricas del clúster
vmagent:
  enabled: true

# VMAlert — evaluador de reglas de alertas y métricas derivadas
vmalert:
  enabled: true
  spec:
    extraArgs:
      notifier.blackhole: "true"

# AlertManager — desactivado (no requerido en esta fase)
alertmanager:
  enabled: false
