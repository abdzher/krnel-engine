# ==============================================================================
# KRNEL — templates/spark-rbac.yaml.j2
# ServiceAccount y RBAC para que los pods de Spark (lanzados desde JupyterHub)
# puedan crear y gestionar recursos dentro del namespace de JupyterHub.
# Renderizado por Ansible — NO editar directamente en el servidor
# ==============================================================================
apiVersion: v1
kind: ServiceAccount
metadata:
  name: spark-editor
  namespace: {{ jupyterhub_namespace }}
  labels:
    app.kubernetes.io/part-of: jupyterhub
    app.kubernetes.io/component: spark-rbac
---
apiVersion: rbac.authorization.k8s.io/v1
kind: Role
metadata:
  name: spark-driver-role
  namespace: {{ jupyterhub_namespace }}
  labels:
    app.kubernetes.io/part-of: jupyterhub
    app.kubernetes.io/component: spark-rbac
rules:
  - apiGroups: [""]
    resources: ["pods", "services", "configmaps", "persistentvolumeclaims"]
    verbs: ["create", "get", "list", "watch", "delete", "patch", "update"]
  - apiGroups: [""]
    resources: ["pods/log", "pods/status"]
    verbs: ["get", "list", "watch"]
---
apiVersion: rbac.authorization.k8s.io/v1
kind: RoleBinding
metadata:
  name: spark-editor-binding
  namespace: {{ jupyterhub_namespace }}
  labels:
    app.kubernetes.io/part-of: jupyterhub
    app.kubernetes.io/component: spark-rbac
subjects:
  - kind: ServiceAccount
    name: spark-editor
    namespace: {{ jupyterhub_namespace }}
roleRef:
  kind: Role
  name: spark-driver-role
  apiGroup: rbac.authorization.k8s.io
