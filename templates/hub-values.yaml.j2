        cpu_guarantee: 1
        mem_limit: "12G"
        mem_guarantee: "1G"
        storage_pvc_ensure: true
        storage_capacity: "5Gi"
        storage_class: {{ storage_class_name }}
        storage_access_modes: ["ReadWriteOnce"]
        service_account: spark-editor
        lifecycle_hooks:
          postStart:
            exec:
              command:
                - /bin/bash
                - -c
                - |
                  POD_IP=$(hostname -I | awk '{print $1}')
                  mkdir -p /home/jovyan/.spark_conf
