# ==============================================================================
# KRNEL — templates/hub-values.yaml.j2
# Valores para el chart jupyterhub/jupyterhub (Zero-to-JupyterHub MRKOV v2)
# Renderizado por Ansible — NO editar directamente en el servidor
#
# Variables sensibles inyectadas desde Ansible Vault:
#   - proxy_token
# ==============================================================================

singleuser:
  image:
    name: quay.io/jupyter/all-spark-notebook
    tag: {{ spark_image_tag }}     # Versión fija — nunca usar latest en producción
    pullPolicy: IfNotPresent
  extraEnv:
    LANG: "C.UTF-8"
    LANGUAGE: "C.UTF-8"
    LC_ALL: "C.UTF-8"
    SPARK_CONF_DIR: "/home/jovyan/.spark_conf"

  cpu:
    limit: 1
    guarantee: 0.5
  memory:
    limit: 2G
    guarantee: 1G

  storage:
    type: dynamic
    capacity: 2Gi
    dynamic:
      storageClass: {{ storage_class_name }}
      pvcNameTemplate: claim-{username}
      volumeNameTemplate: volume-{username}
      storageAccessModes:
        - ReadWriteOnce
    homeMountPath: /home/jovyan

  # ---------------------------------------------------------------------------
  # NetworkPolicy — Spark on K8s requiere:
  #   1. Egress a IPs privadas (API Server, Longhorn RWX, comunicación inter-pod)
  #   2. Ingress desde executor pods (para que conecten de vuelta al driver)
  # ---------------------------------------------------------------------------
  networkPolicy:
    egressAllowRules:
      privateIPs: true
    ingress:
      - from:
          - podSelector:
              matchLabels:
                spark-role: executor

  profileList:
    # --------------------------------------------------------------------------
    # 1. PERFIL INVITADO — efímero, sin almacenamiento persistente
    # SPARK: Modo local[*] únicamente. Sin service_account → no puede lanzar
    #        executor pods al clúster. Limitado a los recursos del pod.
    # --------------------------------------------------------------------------
    - display_name: "Efímero (Invitado)"
      description: "Max. 4GB RAM / 2 CPU. Sin almacenamiento. Todo se borra al salir."
      default: true
      kubespawner_override:
        cpu_limit: 2
        cpu_guarantee: 0.5
        mem_limit: "4G"
        mem_guarantee: "512M"
        storage_pvc_ensure: False
        volumes:
          - name: home-emptydir
            emptyDir: {}
          - name: shared-clases
            persistentVolumeClaim:
              claimName: {{ jupyter_shared_clases_pvc }}
          - name: shared-comunidad
            persistentVolumeClaim:
              claimName: {{ jupyter_shared_comunidad_pvc }}
          - name: shared-repositorio
            persistentVolumeClaim:
              claimName: {{ jupyter_shared_repositorio_pvc }}
        volume_mounts:
          - name: home-emptydir
            mountPath: /home/jovyan
          - name: shared-clases
            mountPath: /home/jovyan/Clases
            readOnly: true
          - name: shared-comunidad
            mountPath: /home/jovyan/Comunidad
            readOnly: true
          - name: shared-repositorio
            mountPath: /home/jovyan/Repositorio
            readOnly: true

    # --------------------------------------------------------------------------
    # 2. PERFIL COMUNIDAD — Alumnos / Tesistas
    # SPARK: Modo clúster habilitado vía spark-defaults.conf inyectado en
    #        postStart. Executors limitados por ResourceQuota del namespace.
    # --------------------------------------------------------------------------
    - display_name: "Comunidad"
      description: "12GB RAM / 8 CPU. 2 GiB persistentes. Escritura en carpeta Comunidad."
      kubespawner_override:
        cpu_limit: 8
        cpu_guarantee: 1
        mem_limit: "12G"
        mem_guarantee: "1G"
        storage_pvc_ensure: true
        storage_capacity: "2Gi"
        storage_class: {{ storage_class_name }}
        storage_access_modes: ["ReadWriteOnce"]
        service_account: spark-editor
        lifecycle_hooks:
          postStart:
            exec:
              command:
                - /bin/bash
                - -c
                - |
                  POD_IP=$(hostname -I | awk '{print $1}')
                  mkdir -p /home/jovyan/.spark_conf
                  cat > /home/jovyan/.spark_conf/spark-defaults.conf << SPARKEOF
                  spark.master                                    k8s://https://kubernetes.default.svc:443
                  spark.kubernetes.container.image                quay.io/jupyter/all-spark-notebook:{{ spark_image_tag }}
                  spark.kubernetes.namespace                      {{ jupyterhub_namespace }}
                  spark.kubernetes.authenticate.driver.serviceAccountName spark-editor
                  spark.executor.instances                        {{ spark_executor_instances }}
                  spark.executor.cores                            {{ spark_executor_cores }}
                  spark.executor.memory                           {{ spark_executor_memory }}
                  spark.executor.memoryOverhead                   {{ spark_executor_memory_overhead }}
                  spark.kubernetes.executor.request.cores          {{ spark_executor_request_cores }}
                  spark.kubernetes.executor.limit.cores            {{ spark_executor_limit_cores }}
                  spark.kubernetes.executor.podTemplateFile        /home/jovyan/.spark_conf/executor-pod-template.yaml
                  spark.kubernetes.executor.podTemplateContainerName spark-kubernetes-executor
                  spark.kubernetes.driver.pod.name                 ${HOSTNAME}
                  spark.kubernetes.executor.deleteOnTermination    true
                  spark.kubernetes.executor.volumes.persistentVolumeClaim.shared-clases.options.claimName {{ jupyter_shared_clases_pvc }}
                  spark.kubernetes.executor.volumes.persistentVolumeClaim.shared-clases.mount.path /home/jovyan/Clases
                  spark.kubernetes.executor.volumes.persistentVolumeClaim.shared-clases.mount.readOnly true
                  spark.kubernetes.executor.volumes.persistentVolumeClaim.shared-comunidad.options.claimName {{ jupyter_shared_comunidad_pvc }}
                  spark.kubernetes.executor.volumes.persistentVolumeClaim.shared-comunidad.mount.path /home/jovyan/Comunidad
                  spark.kubernetes.executor.volumes.persistentVolumeClaim.shared-comunidad.mount.readOnly false
                  spark.kubernetes.executor.volumes.persistentVolumeClaim.shared-repositorio.options.claimName {{ jupyter_shared_repositorio_pvc }}
                  spark.kubernetes.executor.volumes.persistentVolumeClaim.shared-repositorio.mount.path /home/jovyan/Repositorio
                  spark.kubernetes.executor.volumes.persistentVolumeClaim.shared-repositorio.mount.readOnly true
                  spark.driver.host                               ${POD_IP}
                  spark.driver.bindAddress                        0.0.0.0
                  spark.driver.port                               7077
                  spark.blockManager.port                         7078
                  SPARKEOF
                  cat > /home/jovyan/.spark_conf/executor-pod-template.yaml << 'PODEOF'
                  apiVersion: v1
                  kind: Pod
                  spec:
                    containers:
                      - name: spark-kubernetes-executor
                        command:
                          - /bin/bash
                          - -c
                          - exec /usr/local/spark/bin/spark-class org.apache.spark.executor.CoarseGrainedExecutorBackend --driver-url ${SPARK_DRIVER_URL} --executor-id ${SPARK_EXECUTOR_ID} --cores ${SPARK_EXECUTOR_CORES} --app-id ${SPARK_APPLICATION_ID} --hostname ${SPARK_EXECUTOR_POD_IP} --resourceProfileId ${SPARK_RESOURCE_PROFILE_ID}
                  PODEOF
        volumes:
          - name: volume-{username}
            persistentVolumeClaim:
              claimName: claim-{username}
          - name: shared-clases
            persistentVolumeClaim:
              claimName: {{ jupyter_shared_clases_pvc }}
          - name: shared-comunidad
            persistentVolumeClaim:
              claimName: {{ jupyter_shared_comunidad_pvc }}
          - name: shared-repositorio
            persistentVolumeClaim:
              claimName: {{ jupyter_shared_repositorio_pvc }}
        volume_mounts:
          - name: volume-{username}
            mountPath: /home/jovyan
          - name: shared-clases
            mountPath: /home/jovyan/Clases
            readOnly: true
          - name: shared-comunidad
            mountPath: /home/jovyan/Comunidad
            readOnly: false
          - name: shared-repositorio
            mountPath: /home/jovyan/Repositorio
            readOnly: true

