hub:
  baseUrl: /
  config:
    JupyterHub:
      authenticator_class: nativeauthenticator.NativeAuthenticator
      load_groups:
        invitados: []
        comunidad: []
        profesores: []
    Authenticator:
      admin_users:
        - {{ jupyterhub_admin_user }}
      allowed_users:
{% set allowlist_users = lookup('file', allowlist_path | default(playbook_dir + '/../files/allowlist.txt')).splitlines() %}
{% for user in ([jupyterhub_admin_user] + allowlist_users) | map('trim') | map('lower') | unique %}
{% if user %}
        - {{ user }}
{% endif %}
{% endfor %}
      allow_existing_users: false
    NativeAuthenticator:
      enable_signup: true
      open_signup: true
      minimum_password_length: 8

  db:
    type: sqlite-pvc
    pvc:
      storageClassName: {{ storage_class_name }}
      accessModes:
        - ReadWriteOnce
      storage: 1Gi

  # El allowlist se incrusta directamente desde files/allowlist.txt en tiempo
  # de renderizado del template — elimina la necesidad de --set-file en Helm.
  extraFiles:
    lista_de_correos:
      mountPath: /etc/jupyterhub/allowlist.txt
      stringData: |
        {{ lookup('file', allowlist_path | default(playbook_dir + '/../files/allowlist.txt')) | indent(8) }}

  extraConfig:
    logic-grupos: |
      config_profile_list = c.KubeSpawner.profile_list

      async def filtered_profiles(spawner):
          if not config_profile_list:
              return []
          if spawner.user.admin:
              return config_profile_list

          user_groups = [g.name for g in spawner.user.groups]
          mapping = {
              "invitados":  ["Efímero (Invitado)"],
              "comunidad":  ["Comunidad"],
              "profesores": ["Profesor"]
          }

          allowed_titles = []
          for group in user_groups:
              if group in mapping:
                  allowed_titles.extend(mapping[group])

          if not allowed_titles:
              return [config_profile_list[0]]

          return [p for p in config_profile_list if p['display_name'] in allowed_titles]

      c.KubeSpawner.profile_list = filtered_profiles

proxy:
  secretToken: "{{ proxy_token }}"
  service:
    type: NodePort
    nodePorts:
      http: {{ jupyterhub_port }}

scheduling:
  userScheduler:
    enabled: false
  podPriority:
    enabled: false

prePuller:
  hook:
    enabled: false

cull:
  enabled: true
  users: false     # No borrar usuarios de la DB; NativeAuthenticator guarda ahí credenciales
  adminUsers: false
  timeout: 1800    # 30 minutos de inactividad máxima
  maxAge: 43200    # 12 horas de vida máxima por sesión
  every: 600

ingress:
  enabled: true
  annotations:
    kubernetes.io/ingress.class: traefik
  hosts:
    - "{{ jupyterhub_domain }}"
