                  spark.kubernetes.executor.volumes.persistentVolumeClaim.shared-repositorio.mount.path /home/jovyan/Repositorio
                  spark.kubernetes.executor.volumes.persistentVolumeClaim.shared-repositorio.mount.readOnly false
                  spark.driver.host                               ${POD_IP}
                  spark.driver.bindAddress                        0.0.0.0
                  spark.driver.port                               7077
                  spark.blockManager.port                         7078
                  SPARKEOF
                  cat > /home/jovyan/.spark_conf/executor-pod-template.yaml << 'PODEOF'
                  apiVersion: v1
                  kind: Pod
                  spec:
                    containers:
                      - name: spark-kubernetes-executor
                        command:
                          - /bin/bash
                          - -c
                          - exec /usr/local/spark/bin/spark-class org.apache.spark.executor.CoarseGrainedExecutorBackend --driver-url ${SPARK_DRIVER_URL} --executor-id ${SPARK_EXECUTOR_ID} --cores ${SPARK_EXECUTOR_CORES} --app-id ${SPARK_APPLICATION_ID} --hostname ${SPARK_EXECUTOR_POD_IP} --resourceProfileId ${SPARK_RESOURCE_PROFILE_ID}
                  PODEOF
        volumes:
          - name: volume-{username}
            persistentVolumeClaim:
              claimName: claim-{username}
          - name: shared-clases
            persistentVolumeClaim:
              claimName: {{ jupyter_shared_clases_pvc }}
          - name: shared-comunidad
            persistentVolumeClaim:
              claimName: {{ jupyter_shared_comunidad_pvc }}
          - name: shared-repositorio
            persistentVolumeClaim:
              claimName: {{ jupyter_shared_repositorio_pvc }}
        volume_mounts:
          - name: volume-{username}
            mountPath: /home/jovyan
          - name: shared-clases
            mountPath: /home/jovyan/Clases
            readOnly: false
          - name: shared-comunidad
            mountPath: /home/jovyan/Comunidad
            readOnly: false
          - name: shared-repositorio
            mountPath: /home/jovyan/Repositorio
            readOnly: false

    # --------------------------------------------------------------------------
    # 4. PERFIL ADMINISTRADOR
    # SPARK: Modo clúster habilitado. Sin límite de executors fijo — TI
    #        puede sobreescribir spark.executor.instances en su SparkSession.
    # --------------------------------------------------------------------------
    - display_name: "Administrador (Mantenimiento)"
      description: "Acceso raíz a datasets. 5 GiB. Uso exclusivo TI."
      kubespawner_override:
        cpu_limit: 8
        cpu_guarantee: 1
